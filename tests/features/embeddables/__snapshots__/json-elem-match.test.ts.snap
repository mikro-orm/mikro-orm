exports[`$elemMatch on JSON properties [mariadb] > basic $elemMatch queries > $in 1`] = `"[query] select \`e0\`.* from \`event\` as \`e0\` where (select 1 from json_table(\`e0\`.\`tags\`, '$[*]' columns (\`name\` text path '$.name')) as \`__je0\` where \`__je0\`.\`name\` in (?, ?) limit 1) is not null"`;

exports[`$elemMatch on JSON properties [mariadb] > basic $elemMatch queries > $not 1`] = `"[query] select \`e0\`.* from \`event\` as \`e0\` where (select 1 from json_table(\`e0\`.\`tags\`, '$[*]' columns (\`name\` text path '$.name')) as \`__je0\` where not (\`__je0\`.\`name\` = ?) limit 1) is not null"`;

