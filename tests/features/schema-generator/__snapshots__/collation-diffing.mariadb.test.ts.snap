// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`collation diffing [mariadb] > create schema emits column-level collate clause 1`] = `
"set names utf8mb4;

create table \`book\` (\`id\` int unsigned not null auto_increment primary key, \`code\` varchar(26) collate utf8mb4_bin not null, \`name\` varchar(255) not null) default character set utf8mb4 engine = InnoDB;
"
`;

exports[`collation diffing [mariadb] > dropping the property collation modifies the column back to the table default 1`] = `
"alter table \`book\` modify \`code\` varchar(26) not null;
"
`;

exports[`collation diffing [mariadb] > explicit-to-explicit collation change produces a modify 1`] = `
"alter table \`book\` modify \`code\` varchar(26) collate utf8mb4_unicode_ci not null;
"
`;
