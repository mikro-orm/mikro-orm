exports[`partial index [oracle] > emits CASE WHEN functional index and round-trips through introspection > 1-create-with-where 1`] = `
"create table "partial_user" ("id" number(10,0) generated by default as identity not null primary key, "email" varchar2(255) not null, "deleted_at" timestamp(3) null);
create unique index "partial_user_email_uniq" on "partial_user" (case when "deleted_at" is null then "email" end);
"
`;

exports[`partial index [oracle] > emits CASE WHEN functional index and round-trips through introspection > 3-change-where 1`] = `
"drop index "partial_user_email_uniq";
create unique index "partial_user_email_uniq" on "partial_user" (case when "deleted_at" is not null then "email" end);
"
`;
