// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`multiple connected schemas in oracle > schema generator allows creating FKs across different schemas 1`] = `
"create user "s1" identified by "oracle123" default tablespace "mikro_orm" quota unlimited on "mikro_orm";
create user "s2" identified by "oracle123" default tablespace "mikro_orm" quota unlimited on "mikro_orm";
create table "s1"."author" ("id" number(10, 0) generated by default as identity not null primary key, "name" varchar2(255) not null, "mentor_id" number(10, 0) null);
create unique index "author_mentor_id_unique" on "s1"."author" (case when "mentor_id" is not null then "mentor_id" end);

create table "s2"."book" ("id" number(10, 0) generated by default as identity not null primary key, "author_id" number(10, 0) not null, "based_on_id" number(10, 0) null);

alter table "s1"."author" add constraint "author_mentor_id_foreign" foreign key ("mentor_id") references "s1"."author" ("id");

alter table "s2"."book" add constraint "book_author_id_foreign" foreign key ("author_id") references "s1"."author" ("id");
alter table "s2"."book" add constraint "book_based_on_id_foreign" foreign key ("based_on_id") references "s2"."book" ("id");
"
`;

exports[`multiple connected schemas in oracle > schema generator allows creating FKs across different schemas 2`] = `
"alter table "s2"."book" drop constraint "book_author_id_foreign";

alter table "s2"."book" modify "author_id" number(10, 0) null;
alter table "s2"."book" modify "based_on_id" number(10, 0) not null;
alter table "s2"."book" add constraint "book_author_id_foreign" foreign key ("author_id") references "s1"."author" ("id") on delete set null;
"
`;
